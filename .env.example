# Firebase config — get from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase App Check — reCAPTCHA v3 site key for web
# Get from Firebase Console → App Check → web app → provider settings,
# or from google.com/recaptcha/admin. Public, safe to commit.
VITE_APP_CHECK_RECAPTCHA_SITE_KEY=

# Firebase App Check — per-developer debug token (leave blank in production)
# Generate by running the app once: Firebase logs a debug token to the browser
# console (web) or Xcode console (iOS). Copy it here AND register it in
# Firebase Console → App Check → Manage debug tokens.
VITE_APP_CHECK_DEBUG_TOKEN=
